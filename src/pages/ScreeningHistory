    noHistory: sanitize("You haven't saved any screening results yet."),
    takeTest: sanitize("Take a Screening Test"),
    score: sanitize("Score"),
    level: sanitize("Result"),
    date: sanitize("Date"),
    deleteBtn: sanitize("Delete"),
    confirmDelete: sanitize("Delete this result?"),
    loading: sanitize("Loading your history…"),
    pcl5Guide: sanitize("PCL-5 Score Guide"),
    pc5Guide: sanitize("PC-PTSD-5 Score Guide"),
    guides: {
      pcl5: [
        { range: sanitize("0 – 19"), label: sanitize("Minimal symptoms"), color: "#7A9B7A", desc: sanitize("Very few PTSD symptoms. Keep monitoring and using preventive coping tools.") },
        { range: sanitize("20 – 32"), label: sanitize("Moderate symptoms"), color: "#B8A87A", desc: sanitize("Moderate symptoms present. Speaking with a counsellor would be beneficial.") },
